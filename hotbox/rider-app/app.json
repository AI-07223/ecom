{
  "expo": {
    "name": "Hot Box Rider",
    "slug": "hotbox-rider",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hotboxrider",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "android": {
      "package": "site.networkbase75.hotbox.rider",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Hot Box Rider needs your location to share live delivery tracking with the customer.",
          "locationAlwaysPermission": "Hot Box Rider needs background location to keep delivery tracking running while your screen is off.",
          "locationWhenInUsePermission": "Hot Box Rider uses your location to share live delivery tracking with the customer.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#fcd34d"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "cd7fe86c-1e37-401d-846d-47b9f8897887"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "zeddeye"
  }
}
