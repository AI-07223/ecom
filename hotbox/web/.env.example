# Database (Postgres) - point at the Coolify-managed platform-postgres
# Use the 'hotbox' logical database. Connection pool config tuned to keep
# Next.js's serverless-ish process lean.
DATABASE_URL="postgres://USER:PASS@platform-postgres:5432/hotbox?schema=public&connection_limit=10"

# Cashfree (sandbox in dev; production credentials set per-deployment)
CASHFREE_APP_ID=""
CASHFREE_SECRET_KEY=""
CASHFREE_ENV="sandbox"
CASHFREE_WEBHOOK_SECRET=""

# Map provider (Mapbox public token, referrer-locked in production)
NEXT_PUBLIC_MAPBOX_TOKEN=""

# OTP provider (MSG91 default; "cashfree" also supported)
OTP_PROVIDER="msg91"
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""
MSG91_SENDER_ID="HOTBOX"

# Admin login: any OTP login from this phone gets role=admin
ADMIN_PHONE="+919999999999"

# JWT signing for session cookie (use `openssl rand -hex 64`)
JWT_SECRET=""

# Public base URL (used in install-guide page, QR codes, share links)
PUBLIC_BASE_URL="https://hotbox.networkbase75.site"

# Rider APK distribution
LATEST_APK_VERSION="0.1.0"
