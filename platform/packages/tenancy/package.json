{
  "name": "@platform/tenancy",
  "version": "0.0.1",
  "private": true,
  "description": "Tenant types, hostname resolver, in-process cache, and theme-token helpers shared between the storefront and the seed script.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "pg": "8.13.1"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "@types/pg": "8.11.10",
    "rimraf": "6.0.1",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
