# Platform configuration — copy this file to .env and adjust as needed.
# All values are placeholders safe for local development; replace before any
# production deploy.

# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=platform
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=platform
# Host port mapping. The default 5432 collides with a Windows-native Postgres
# install on some machines (Chocolatey postgresql16, the EDB installer, etc.).
# Bump to 54320 if you see "password authentication failed" on the first
# `npm run migrate:platform` — the Windows service is shadowing the container.
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Medusa backend ──────────────────────────────────────────────────────────
# Host port mapping for the Medusa API + admin.
MEDUSA_PORT=9000
# Secrets used by Medusa for JWTs and admin session cookies. Use long random
# strings in production (e.g. `openssl rand -hex 32`).
JWT_SECRET=change-me-jwt-secret
COOKIE_SECRET=change-me-cookie-secret
# CORS lists (comma-separated). Local defaults match the storefront port.
STORE_CORS=http://localhost:3000,http://acme.localhost:3000,http://globex.localhost:3000
ADMIN_CORS=http://localhost:9000,http://localhost:7001
AUTH_CORS=http://localhost:3000,http://acme.localhost:3000,http://globex.localhost:3000
# Initial admin user provisioned by the seed script.
MEDUSA_ADMIN_EMAIL=admin@platform.local
MEDUSA_ADMIN_PASSWORD=change-me-admin-password

# ─── Storefront ──────────────────────────────────────────────────────────────
STOREFRONT_PORT=3000
# Public Medusa API URL the storefront uses from the browser. For local dev
# the storefront talks to Medusa over the Compose network (http://medusa:9000)
# server-side; the browser uses this URL for any client-side Medusa calls.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# ─── Coolify-only (production) ──────────────────────────────────────────────
# Only consumed when compose.coolify.yml is layered on top of compose.yml.
# Set in the Coolify project's environment, not in a committed file.
# PLATFORM_DOMAIN=platform.example.com
# WILDCARD_DOMAIN=*.platform.example.com
